<?xml version="1.0" ?>
<robot name="bush">
  <link name="baseLink">

    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.0"/> 
      <geometry>
        <mesh filename="bush.obj" scale="1 1 1"/>
      </geometry>
    </visual>
    
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0.0"/> 
      <geometry>
        <mesh filename="bush.obj" scale="1 1 1"/>
        
        </geometry>
    </collision>

    <inertial>
      <mass value="0.0"/> <origin rpy="0 0 0" xyz="0 0 0.0"/>
      <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/>
    </inertial>
    
  </link>
</robot>