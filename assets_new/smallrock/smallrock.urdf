<?xml version="1.0" ?>
<robot name="smallrock">
  <link name="baseLink">
    <inertial>
      <mass value="0.0"/>
      <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/>
    </inertial>
    
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.0"/> 
