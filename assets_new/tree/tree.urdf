<?xml version="1.0" ?>
<robot name="tree">
  <link name="baseLink">
    <inertial>
      <mass value="0.0"/>
      <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.0"/> 
      <geometry>
        <mesh filename="tree.obj" scale="1 1 1"/>
      </geometry>
      <material name="brown">
        <color rgba="0.4 0.2 0.1 1.0"/>
      </material>
    </visual>
    
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0.0"/> 
      <geometry>
        <mesh filename="tree.obj" scale="1 1 1"/>
        
        </geometry>
    </collision>
  </link>
</robot>